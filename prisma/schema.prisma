// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  orang_tua
  kader
  puskesmas
}

enum TipeWilayah {
  desa
  kelurahan
  puskesmas
}

enum JenisKelamin {
  laki_laki
  perempuan
}

model Wilayah {
  id           String      @id @default(uuid())
  nama_wilayah String      @db.VarChar(255)
  tipe         TipeWilayah
  users        User[]

  @@map("wilayah")
}

model User {
  id         String   @id @default(uuid())
  name       String   @db.VarChar(255)
  email      String   @unique @db.VarChar(255)
  password   String   @db.VarChar(255)
  role       Role
  wilayah_id String?
  created_at DateTime @default(now()) @db.Timestamp(0)
  
  wilayah    Wilayah? @relation(fields: [wilayah_id], references: [id])
  anak       Anak[]

  @@map("users")
}

model Anak {
  id            String       @id @default(uuid())
  user_id       String
  nama          String       @db.VarChar(255)
  tanggal_lahir DateTime     @db.Date
  jenis_kelamin JenisKelamin
  created_at    DateTime     @default(now()) @db.Timestamp(0)

  user          User         @relation(fields: [user_id], references: [id])
  pertumbuhan   Pertumbuhan[]
  imunisasi     Imunisasi[]

  @@map("anak")
}

model Imunisasi {
  id         String   @id @default(uuid())
  anak_id    String
  tanggal    DateTime @db.Date
  nama_vaksin String  @db.VarChar(255)
  keterangan String?  @db.Text
  created_at DateTime @default(now()) @db.Timestamp(0)

  anak       Anak     @relation(fields: [anak_id], references: [id])

  @@map("imunisasi")
}

model Pertumbuhan {
  id                 String   @id @default(uuid())
  anak_id            String
  tanggal_pengukuran DateTime @db.Date
  berat_badan        Float
  tinggi_badan       Float
  lingkar_kepala     Float?
  umur_bulan         Int?
  zscore_tbu         Float?
  kategori_tbu       String?  @db.VarChar(50)
  zscore_bbu         Float?
  kategori_bbu       String?  @db.VarChar(50)
  zscore_bbtb        Float?
  kategori_bbtb      String?  @db.VarChar(50)
  created_at         DateTime @default(now()) @db.Timestamp(0)

  anak               Anak     @relation(fields: [anak_id], references: [id])

  @@map("pertumbuhan")
}

model WhoReference {
  id            String       @id @default(uuid())
  jenis_kelamin JenisKelamin
  umur_bulan    Int
  indikator     String       @db.VarChar(20)
  tinggi_cm     Float?
  l             Float
  m             Float
  s             Float

  @@map("who_reference")
}
